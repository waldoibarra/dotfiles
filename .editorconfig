root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100
indent_style = space
indent_size = 2
charset = utf-8

[*.md]
max_line_length = off

# Git config format uses tabs by design and aliases can exceed 100 chars.
[{.gitconfig,home/.gitconfig,home/.gitconfig-parasiempre,.gitmodules}]
indent_style = tab
max_line_length = off

# Brewfile descriptions and install.conf.yaml shell commands can exceed 100 chars.
[{home/.Brewfile,install.conf.yaml}]
max_line_length = off

# `npx skills update` command modifies this JSON file, leaving no new line at the end of the file.
[home/.agents/.skill-lock.json]
insert_final_newline = false
