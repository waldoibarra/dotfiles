amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

hooks {
  ["pre-commit"] {
    steps {
      ["shellcheck"] {
        glob = List("scripts/**/*.sh", "scripts/.shellcheckrc")
        check = "just lint-sh"
      }
      ["markdownlint"] {
        glob = List("**/*.md", ".markdownlint-cli2.yaml")
        check = "just lint-md"
      }
    }
  }
  ["commit-msg"] {
    steps {
      ["committed"] {
        check = "just lint-commit {{commit_msg_file}}"
      }
    }
  }
}
