{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "plugin": [
    "opencode-agents-cascade@git+https://github.com/waldoibarra/opencode-agents-cascade.git"
  ],
  "provider": {
    "ollama": {
      "models": {
        "qwen3": {
          "name": "Qwen3 (latest)"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      }
    }
  }
}
